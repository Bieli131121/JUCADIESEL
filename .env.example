# Copie este arquivo para ".env" e preencha com os dados do seu projeto Supabase
# (Configurações do projeto > API, em app.supabase.com)

VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Se não configurar nada, o sistema roda em modo local (localStorage) automaticamente.

# Focus NFe — necessário apenas para emissão real de Nota Fiscal (NFe/NFS-e).
# Gere o token no painel do Focus NFe (focusnfe.com.br) após cadastrar sua empresa.
# NUNCA compartilhe esse token nem cometa (commit) este arquivo com os valores preenchidos.
FOCUS_NFE_TOKEN_HOMOLOGACAO=
FOCUS_NFE_TOKEN_PRODUCAO=

# Proteção do proxy — dificulta que alguém de fora chame /api/focus-nfe diretamente.
# Escolha qualquer valor (ex: gere um em https://generate-secret.vercel.app/32) e
# use O MESMO valor tanto aqui quanto nas variáveis de ambiente da Vercel.
VITE_PROXY_SHARED_KEY=

# Opcional (só no deploy web/Vercel) — URL onde o sistema está publicado, usada
# como camada extra de proteção do proxy. Ex: https://sua-oficina.vercel.app
ALLOWED_ORIGIN=
